      {
       "trackRemaining": true
      }
     ]
    }
   }
  },
  "type.googleapis.com/envoy.config.listener.v3.Listener": {
   "self_inbound_dp_8080": {
    "name": "self_inbound_dp_8080",
    "address": {
     "socketAddress": {
      "address": "127.0.0.1",
      "portValue": 8080
     }
    },
    "statPrefix": "self_inbound_dp_8080",
    "filterChains": [
     {
      "filters": [
       {
        "name": "envoy.filters.network.tcp_proxy",
