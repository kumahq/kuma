        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "title": "Uptime by Pod",
      "description": "Recently restarted proxies appear with short bars. Red < 1h, Yellow < 24h, Green > 24h.",
      "type": "bargauge",
      "targets": [
        {
          "expr": "sort_desc(envoy_server_uptime{mesh=\"$mesh\"})",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 52428800
              },
              {
                "color": "red",
                "value": 104857600
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
